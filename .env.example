# ── LLM Provider ──────────────────────────────────────────────────────────
# 'bedrock' (recommended) — no external API key needed, fully AWS-native.
#   Requires Bedrock access to claude-3-haiku-20240307-v1:0 in your region.
# 'openai' — requires OPENAI_API_KEY below.
LLM_PROVIDER=bedrock

# Required only when LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...

# ── AWS resources (populated automatically by SAM after deploy) ────────────
DYNAMODB_TABLE=whatsapp-triage-dev-conversations
S3_BUCKET=whatsapp-triage-dev-transcripts
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:whatsapp-triage-dev-alerts
AWS_REGION=us-east-1

# ── Twilio ─────────────────────────────────────────────────────────────────
# Find these in the Twilio Console → Account → API keys & tokens
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
